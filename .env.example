SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NODE_ENV=development
PORT=3001

# Shared secret the Climate Agent sends as the X-Climate-Agent-Key header
# when POSTing to /api/climate/block-summary/ingest
CLIMATE_AGENT_API_KEY=your-climate-agent-api-key

# Frontend (client/.env or Railway environment variables)
# Omit for local dev (defaults to http://localhost:3001)
# VITE_API_BASE_URL=https://your-railway-backend.up.railway.app
